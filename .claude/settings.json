{
  "permissions": {
    "allow": [
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.env_devops|*.sops.yaml|*/.talos/*) echo 'BLOCK: This is a sensitive file (.env_devops, .sops.yaml, or .talos/ config). Please confirm with the user before editing.' >&2; exit 2;; *) exit 0;; esac"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/plan-validate-check.sh",
            "statusMessage": "Validating plan header..."
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/plan-archive-check.sh",
            "statusMessage": "Checking plan archive status..."
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/plan-checklist-check.sh",
            "statusMessage": "Checking post-deploy checklist..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "blog-craft@blog-craft": true
  }
}
