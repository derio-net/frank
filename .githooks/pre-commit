#!/usr/bin/env bash
# Validate plan file headers on commits that touch plan files.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Collect staged plan files
PLAN_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^docs/superpowers/(plans|archived-plans)/.*\.md$' || true)

if [ -n "$PLAN_FILES" ]; then
  # shellcheck disable=SC2086
  "$REPO_ROOT/scripts/validate-plans.sh" $PLAN_FILES
fi
