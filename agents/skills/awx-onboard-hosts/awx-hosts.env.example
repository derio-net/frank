# Copy to scripts/tmp/awx-hosts.env (gitignored) and fill in. NO secrets here —
# only paths, host metadata, object names. The private key stays in ~/.ssh/.
#
# Flow: 01-key-onboard.sh -> 02-wire-up.sh -> 03-formalize.sh
#
# REACHABILITY: AWX runs IN the cluster, so each AWX_HOST must be reachable from a
# cluster pod (a LAN IP), NOT a Mac-only ssh alias. The SSH_ALIAS is only used on
# your Mac for ssh-copy-id.

# ---- New dedicated AWX SSH key ---------------------------------------------
AWX_KEY_PATH="$HOME/.ssh/frank_awx_ed25519"
AWX_KEY_TYPE="ed25519"
AWX_KEY_COMMENT="awx@frank"

# ---- Target hosts ----------------------------------------------------------
# One per line:  <SSH_ALIAS> | <AWX_HOST> | <ANSIBLE_USER> | <BECOME true/false>
# AWX_HOST / ANSIBLE_USER blank => resolved from `ssh -G <SSH_ALIAS>`.
AWX_HOSTS="
# my-host-alias | 192.168.x.x | someuser | false
"

# ---- AWX objects -----------------------------------------------------------
AWX_ORG="Homelab"
AWX_INVENTORY="frank-homelab"
AWX_CREDENTIAL="frank-awx-ssh"
AWX_JOB_TEMPLATE="smoke-ping"
AWX_PLAYBOOK="ping.yml"

# ---- Playbook source (Project SCM) -----------------------------------------
AWX_PROJECT_NAME="frank-ansible-playbooks"
AWX_PROJECT_SCM_URL=""          # blank => a Gitea repo is created
AWX_PROJECT_SCM_BRANCH="main"

# ---- AWX endpoint (admin password read live from k8s; never stored here) ----
AWX_API_URL="https://awx.cluster.derio.net"
